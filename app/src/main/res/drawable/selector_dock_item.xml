<?xml version="1.0" encoding="utf-8"?>
<!--
    selector_dock_item.xml
    State-list drawable for every icon button inside the
    creative dock and source-picker row.
    Gives subtle visual feedback without a ripple that would
    look odd on a frosted-glass surface.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed: brighter fill -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#40FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Focused (keyboard/D-pad navigation) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#30FFFFFF" />
            <stroke android:width="1dp" android:color="#60FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Default: transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>