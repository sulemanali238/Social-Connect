<?xml version="1.0" encoding="utf-8"?>
<!--suppress ALL -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOP BAR (unchanged) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#1E293B"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginStart="12dp"/>


        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"/>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="36dp">

                <!-- ── HERO AVATAR CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/teal_green"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="28dp"
                        android:paddingBottom="24dp">

                        <!-- Avatar with camera badge -->
                        <FrameLayout
                            android:layout_width="90dp"
                            android:layout_height="90dp">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/imgEditAvatar"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:src="@drawable/ic_avatar"
                                app:civ_border_width="3dp"
                                app:civ_border_color="#FFFFFF"/>

                            <FrameLayout
                                android:id="@+id/btnPickImage"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:background="@drawable/bg_circle_teal"
                                android:layout_gravity="bottom|end"
                                android:clickable="true"
                                android:focusable="true"
                                android:elevation="4dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_camera"
                                    app:tint="#FFFFFF"/>

                            </FrameLayout>

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvChangePhoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change Photo"
                            android:textColor="#FFFFFFCC"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_medium"
                            android:layout_marginTop="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to update your profile photo"
                            android:textColor="#FFFFFF80"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── PROFILE INFO LABEL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFILE INFO"
                    android:textColor="@color/teal_green"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.12"
                    android:paddingStart="24dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"/>

                <!-- ── FIELDS CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Full Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilFullName"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Name"
                            app:hintTextColor="@color/teal_green"
                            app:boxStrokeColor="@color/teal_green"
                            app:boxStrokeWidth="1dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="20dp"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFullName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName|textCapWords"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_regular"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="52dp"
                            android:background="#F0F0F0" />

                        <!-- Username -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilUsername"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Username"
                            app:hintTextColor="@color/teal_green"
                            app:boxStrokeColor="@color/teal_green"
                            app:boxStrokeWidth="1dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="20dp"
                            app:prefixText="@"
                            app:prefixTextColor="#9CA3AF"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUsername"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textNoSuggestions"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_regular"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── ABOUT LABEL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textColor="@color/teal_green"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.12"
                    android:paddingStart="24dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"/>

                <!-- ── BIO + WEBSITE CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Bio -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBio"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Bio"
                            app:hintTextColor="@color/teal_green"
                            app:boxStrokeColor="@color/teal_green"
                            app:boxStrokeWidth="1dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="20dp"
                            app:counterEnabled="true"
                            app:counterMaxLength="150">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBio"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine|textCapSentences"
                                android:minLines="3"
                                android:gravity="top"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_regular"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="52dp"
                            android:layout_marginTop="10dp"
                            android:background="#F0F0F0" />

                        <!-- Website -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilWebsite"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Website (optional)"
                            app:hintTextColor="@color/teal_green"
                            app:boxStrokeColor="@color/teal_green"
                            app:boxStrokeWidth="1dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:layout_marginTop="10dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="20dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etWebsite"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textWebEmailAddress"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_regular"/>

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── TIP CARD ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#EFF6FF"
                    app:strokeColor="#BFDBFE"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lock"
                            app:tint="#3B82F6"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your profile info is visible to other users. Keep your bio friendly and engaging!"
                            android:textColor="#1D4ED8"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_marginStart="12dp"
                            android:lineSpacingExtra="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── SAVE BUTTON ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveBottom"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Save Changes"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.04"
                    app:backgroundTint="@color/teal_green"
                    app:cornerRadius="16dp"
                    app:rippleColor="#00897B"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="20dp"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</RelativeLayout>