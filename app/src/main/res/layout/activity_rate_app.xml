<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4">

    <!-- ── TOP BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#1E293B"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rate the App"
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"/>

    <!-- ── SCROLL CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── HEADER CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#00BFA5"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rate the App"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Your feedback matters to us"
                        android:textColor="#E0F7F4"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Help us improve by sharing your experience. Rate us on the store or leave a written review."
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION LABEL: YOUR RATING ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="6dp"
                android:text="YOUR RATING"
                android:textColor="#00BFA5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <!-- ── STAR RATING CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How would you rate your experience?"
                        android:textColor="#1A1A2E"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <!-- Star row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/star1"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star"
                            android:layout_marginEnd="6dp"
                            app:tint="#FFA726"
                            android:clickable="true"
                            android:focusable="true"/>

                        <ImageView
                            android:id="@+id/star2"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star"
                            android:layout_marginEnd="6dp"
                            app:tint="#FFA726"
                            android:clickable="true"
                            android:focusable="true"/>

                        <ImageView
                            android:id="@+id/star3"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star"
                            android:layout_marginEnd="6dp"
                            app:tint="#FFA726"
                            android:clickable="true"
                            android:focusable="true"/>

                        <ImageView
                            android:id="@+id/star4"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star"
                            android:layout_marginEnd="6dp"
                            app:tint="#FFA726"
                            android:clickable="true"
                            android:focusable="true"/>

                        <ImageView
                            android:id="@+id/star5"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_star_outline"
                            app:tint="#CCCCCC"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRatingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Very Good"
                        android:textColor="#00BFA5"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION LABEL: LEAVE A REVIEW ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="6dp"
                android:text="LEAVE A REVIEW"
                android:textColor="#00BFA5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <!-- ── REVIEW CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Write your review (optional)"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etReview"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:hint="Tell us what you love or what we can improve..."
                        android:textColorHint="#BBBBBB"
                        android:textColor="#1A1A2E"
                        android:textSize="13sp"
                        android:gravity="top|start"
                        android:padding="12dp"
                        android:background="@drawable/bg_input_field"
                        android:inputType="textMultiLine"
                        android:maxLines="5"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION LABEL: ACTIONS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="6dp"
                android:text="ACTIONS"
                android:textColor="#00BFA5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <!-- ── ACTIONS CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Rate on Play Store -->
                    <LinearLayout
                        android:id="@+id/rowRatePlayStore"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_star"
                            app:tint="#00BFA5"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Rate on Google Play"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#AAAAAA"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="52dp"
                        android:background="#F0F0F0"/>

                    <!-- Submit Feedback -->
                    <LinearLayout
                        android:id="@+id/rowSubmitFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_send"
                            app:tint="#00BFA5"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="Submit Feedback to Team"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#AAAAAA"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── INFO NOTE ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_info_note"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info"
                    app:tint="#00BFA5"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Ratings on the Play Store help others discover the app and motivate our team to keep improving. Thank you!"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>