<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar container with rings -->
    <FrameLayout
        android:layout_width="62dp"
        android:layout_height="62dp">

        <!-- UNSEEN ring: solid teal gradient — visible by default -->
        <View
            android:id="@+id/ringUnseen"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:background="@drawable/shape_story_ring_unseen"
            android:visibility="visible"/>

        <!-- SEEN ring: light gray — hidden by default -->
        <View
            android:id="@+id/ringSeen"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:background="@drawable/shape_story_ring_seen"
            android:visibility="gone"/>

        <!-- Story thumbnail image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgStoryAvatar"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_avatar"
            app:civ_border_width="0dp"/>

    </FrameLayout>

    <!-- Username + time / seen -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvStoryFullName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1E293B"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"/>

        <!-- Time shown when UNSEEN -->
        <TextView
            android:id="@+id/tvStoryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="1dp"
            android:visibility="visible"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/ivMoreOptions"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_more_vert"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:tint="#94A3B8"/>

</LinearLayout>