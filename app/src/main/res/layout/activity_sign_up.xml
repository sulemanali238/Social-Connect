<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FF">

    <!-- Big blue circle top-right -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/shape_circle_blue_filled"
        android:alpha="0.13"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-110dp"
        android:layout_marginEnd="-110dp"/>

    <!-- Medium blue ring top-right -->
    <View
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:background="@drawable/shape_circle_blue_stroke"
        android:alpha="0.28"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="-24dp"/>

    <!-- Small indigo circle bottom-left -->
    <View
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/shape_circle_indigo_filled"
        android:alpha="0.22"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-38dp"
        android:layout_marginStart="-38dp"/>

    <!-- Tiny blue circle mid-left -->
    <View
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/shape_circle_blue_filled"
        android:alpha="0.28"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="-16dp"
        android:layout_marginTop="-80dp"/>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_back_button"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginTop="36dp"
                android:contentDescription="Back"/>

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create\nAccount"
                android:textColor="@color/accent_blue"
                android:textSize="28sp"
                android:fontFamily="@font/poppins_bold"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join the Social Connect community"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="28dp"/>

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFullName"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full Name"
                app:hintTextColor="@color/accent_blue"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Username -->
            <!--suppress AndroidDomInspection -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Username"
                app:hintTextColor="@color/accent_blue"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:prefixText="@"
                app:prefixTextColor="#9CA3AF"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Email"
                app:hintTextColor="@color/accent_blue"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Password"
                app:hintTextColor="@color/accent_blue"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:endIconMode="password_toggle"
                app:endIconTint="#9CA3AF"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Confirm Password"
                app:hintTextColor="@color/accent_blue"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:endIconMode="password_toggle"
                app:endIconTint="#9CA3AF"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Terms checkbox -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I agree to the Terms of Service and Privacy Policy"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                app:buttonTint="@color/accent_blue"
                android:layout_marginTop="16dp"/>

            <!-- Create Account Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0.04"
                app:backgroundTint="@color/accent_blue"
                app:cornerRadius="12dp"
                app:rippleColor="#1E40AF"
                android:layout_marginTop="20dp"/>

            <!-- Login Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log In"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>