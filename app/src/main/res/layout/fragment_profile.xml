<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile"
            android:textSize="32sp"
            android:fontFamily="@font/poppins_medium"/>

        <!-- Settings -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_setting"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#1E293B"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <!-- Avatar with edit button -->
                    <FrameLayout
                        android:layout_width="96dp"
                        android:layout_height="96dp">

                        <!-- Smooth grey-black avatar background -->
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:src="@drawable/ic_avatar"
                            app:civ_border_width="3dp"
                            app:civ_border_color="#E0F5F1"/>

                        <!-- Edit avatar button -->
                        <FrameLayout
                            android:id="@+id/btnEditAvatar"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/bg_circle_teal"
                            android:layout_gravity="bottom|end"
                            android:clickable="true"
                            android:focusable="true"
                            android:elevation="4dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>

                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="#1E293B"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginTop="14dp"/>

                    <!-- Username -->
                    <!--suppress AndroidDomInspection -->
                    <TextView
                        android:id="@+id/tvProfileUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@username"
                        android:textColor="@color/teal_green"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginTop="2dp"/>

                    <!-- Bio -->
                    <TextView
                        android:id="@+id/tvProfileBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No bio yet."
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F3F4F6"
                        android:layout_marginTop="20dp"/>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <!-- Posts -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvPostCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1E293B"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Posts"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_regular"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="#E5E7EB"/>

                        <!-- Followers -->
                        <LinearLayout
                            android:id="@+id/btnFollowers"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <TextView
                                android:id="@+id/tvFollowerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1E293B"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Followers"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_regular"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center_vertical"
                            android:background="#E5E7EB"/>

                        <!-- Following -->
                        <LinearLayout
                            android:id="@+id/btnFollowing"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <TextView
                                android:id="@+id/tvFollowingCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1E293B"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Following"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_regular"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Edit Profile Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Edit Profile"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold"
                        app:backgroundTint="@color/teal_green"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Posts label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Posts"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:id="@+id/tvPostCount2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 posts"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

            <!-- Posts Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfilePosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="20dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>