<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Top Bar ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#1E293B"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="New Post"
                android:textColor="#1E293B"
                android:textSize="17sp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPost"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Post"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"
                android:minWidth="72dp"
                app:backgroundTint="@color/teal_green"
                app:cornerRadius="18dp"
                app:elevation="0dp"/>

        </LinearLayout>

        <!-- Subtle divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EFF2F5"/>

        <!-- ── Scrollable body ─────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── User row ──────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp"
                    android:background="#FFFFFF">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgUserAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_avatar"
                        app:civ_border_width="2dp"
                        app:civ_border_color="#E0F5F1"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvPostFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Name"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <LinearLayout
                            android:id="@+id/btnAudience"
                            android:layout_width="wrap_content"
                            android:layout_height="22dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_audience_selector"
                            android:paddingStart="8dp"
                            android:paddingEnd="6dp"
                            android:layout_marginTop="3dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/tvAudience"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Everyone"
                                android:textColor="@color/teal_green"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_arrow_right"
                                android:rotation="90"
                                app:tint="#00BFA5"
                                android:layout_marginStart="3dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Caption input ────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <EditText
                        android:id="@+id/etCaption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="What's on your mind?"
                        android:textColorHint="#C0CAD4"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_regular"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="5"
                        android:gravity="top"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>

                <!-- ── Image tray (horizontal scroll of selected images) -->
                <LinearLayout
                    android:id="@+id/layoutImageTray"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="#FFFFFF"
                    android:paddingBottom="12dp">

                    <!-- Thin teal accent line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#E0F5F1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHOTOS"
                        android:textColor="#00BFA5"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_bold"
                        android:letterSpacing="0.12"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="8dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:clipToPadding="false">

                        <!-- Image thumbnails injected programmatically -->
                        <LinearLayout
                            android:id="@+id/llImageThumbnails"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"/>

                    </HorizontalScrollView>

                </LinearLayout>

                <!-- Gap -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#F0F4F8"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ── Bottom toolbar ──────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EFF2F5"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:background="#FFFFFF">

            <!-- Gallery -->
            <LinearLayout
                android:id="@+id/btnAddImage"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_image"
                    app:tint="@color/teal_green"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photo"
                    android:textColor="@color/teal_green"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- Camera -->
            <LinearLayout
                android:id="@+id/btnCamera"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_camera"
                    app:tint="#64748B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Image count badge -->
            <TextView
                android:id="@+id/tvImageCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="#00BFA5"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingEnd="8dp"/>

            <!-- Char count -->
            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/500"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>