<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Big blue circle top-right -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/shape_circle_blue_filled"
        android:alpha="0.13"
        android:layout_gravity="top|end"
        android:layout_marginTop="-110dp"
        android:layout_marginEnd="-110dp"/>

    <!-- Medium blue ring top-right -->
    <View
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:background="@drawable/shape_circle_blue_stroke"
        android:alpha="0.28"
        android:layout_gravity="top|end"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="-24dp"/>

    <!-- Small indigo circle bottom-left -->
    <View
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/shape_circle_blue_filled"
        android:alpha="0.22"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-38dp"
        android:layout_marginStart="-38dp"/>

    <!-- Tiny blue circle mid-left -->
    <View
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/shape_circle_blue_filled"
        android:alpha="0.30"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="-16dp"
        android:layout_marginTop="-80dp"/>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Top spacer: pushes logo+name down from top -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.2"/>

        <!-- Logo Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="20dp"
            android:layout_marginLeft="7dp"
            app:cardBackgroundColor="#E0F5F1"
            app:cardElevation="8dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo"
                app:tint="@color/teal_green"/>

        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Social\nConnect"
            android:textColor="@color/teal_green"
            android:textSize="60sp"
            android:fontFamily="@font/outfit_extra_bold"
            android:lineSpacingMultiplier="0.95"
            android:layout_marginTop="30dp"/>

        <!-- Middle spacer: equal breathing room between name and features -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Feature row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_circle_blue">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_post"
                    app:tint="@color/teal_green"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Post Updates"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share text and photos with your followers"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Feature row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_circle_blue">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_people"
                    app:tint="@color/teal_green"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Follow People"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discover and connect with new people"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Feature row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_circle_blue">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/teal_green"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay Notified"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get notified on likes, comments and more"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom spacer: equal space between features and buttons -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="36dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetStarted"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@color/teal_green"
                app:cornerRadius="12dp"
                app:rippleColor="#00897B"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToLogin"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="I already have an account"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                app:strokeColor="#DDDDDD"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                app:rippleColor="#E0E0E0"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>