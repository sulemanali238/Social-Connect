<?xml version="1.0" encoding="utf-8"?>
<!-- item_region_row.xml — single audience region row -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingBottom="10dp">

    <!-- Flag / emoji container -->
    <TextView
        android:id="@+id/tvRegionFlag"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="18sp"
        android:background="@drawable/bg_flag_circle"
        android:text="🇵🇰"/>

    <TextView
        android:id="@+id/tvRegionName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Pakistan"
        android:textColor="#1E293B"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginStart="10dp"/>

    <!-- Mini progress bar -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="6dp"
        android:background="@drawable/bg_bar_track"
        android:layout_marginEnd="10dp">

        <View
            android:id="@+id/viewRegionBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_bar_fill"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tvRegionPct"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:text="42%"
        android:textColor="#0F6E56"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_medium"
        android:gravity="end"/>

</LinearLayout>