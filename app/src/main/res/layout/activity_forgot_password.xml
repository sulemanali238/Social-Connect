<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <RelativeLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8F5F0">

        <!-- Decorative Accents (Matching Login) -->
        <ImageView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:src="@drawable/bg_corner_tl"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:contentDescription="@null"/>
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/bg_corner_br"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:contentDescription="@null"/>

        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_notif_badge_teal"
            android:alpha="0.10"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-30dp"
            android:layout_marginEnd="-30dp"/>

        <!-- Main Card Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Back button -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_back"
                    android:background="@drawable/bg_back_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="7dp"
                    android:layout_marginBottom="14dp"
                    android:contentDescription="Back"/>

                <!-- Icon -->
                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_avatar_teal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="FORGOT PASSWORD"
                    android:textColor="@color/teal_green"
                    android:textSize="9sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.20"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Reset your link"
                    android:textColor="@color/teal_green_heading"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Enter your email to receive instructions"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="18dp"/>

                <!-- Success Card (Inside the main card) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardBackgroundColor="#EFF6FF"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#BFDBFE"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Reset link sent! Check your inbox."
                        android:textColor="#1D4ED8"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Error Card — email not found -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FEF2F2"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#FECACA"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="No account found with this email address."
                        android:textColor="#DC2626"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"/>

                </com.google.android.material.card.MaterialCardView>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    app:hintTextColor="@color/teal_green"
                    app:boxStrokeColor="@color/teal_green"
                    app:boxStrokeWidth="1.5dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#9CA3AF"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendReset"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Send Reset Link"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold"
                    app:backgroundTint="@color/teal_green"
                    app:cornerRadius="12dp"
                    android:layout_marginTop="15dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
</ScrollView>