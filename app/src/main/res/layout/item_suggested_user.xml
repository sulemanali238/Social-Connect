<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="100dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E5E7EB"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgSuggestedAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_avatar"/>

        <TextView
            android:id="@+id/tvSuggestedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="11sp"
            android:textColor="#1A1A1D"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvSuggestedUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="10sp"
            android:textColor="#6B7280"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"/>

        <Button
            android:id="@+id/btnSuggestedFollow"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="6dp"
            android:textSize="9sp"
            android:textAllCaps="false"
            android:fontFamily="@font/poppins_medium"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/teal_green"
            app:cornerRadius="14dp"
            android:text="Follow"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>