<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stories"
                android:textColor="#000000"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"/>

        <!-- My Story Row -->
        <LinearLayout
            android:id="@+id/layoutMyStory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="62dp"
                android:layout_height="62dp">

                <View
                    android:id="@+id/myStoryRingUnseen"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/shape_story_ring_unseen"
                    android:visibility="gone"/>

                <View
                    android:id="@+id/myStoryRingSeen"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/shape_story_ring_seen"
                    android:visibility="gone"/>

                <View
                    android:id="@+id/myStoryRingDashed"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_story_ring_dashed"
                    android:visibility="visible"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgMyAvatar"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_avatar"
                    app:civ_border_width="0dp"/>

                <FrameLayout
                    android:id="@+id/badgePlus"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_circle_teal"
                    android:layout_gravity="bottom|end"
                    android:elevation="2dp"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_plus"
                        app:tint="#FFFFFF"/>

                </FrameLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Story"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:id="@+id/tvMyStoryStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to add story"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="1dp"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/ivMyStoryMore"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_right"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#94A3B8"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginStart="16dp"/>

        <!-- Loading overlay -->
        <FrameLayout
            android:id="@+id/layoutStoryLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:visibility="visible"
            android:elevation="10dp">

            <ProgressBar
                android:id="@+id/storyLoadingBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminate="true"/>

        </FrameLayout>

        <!-- SwipeRefreshLayout wrapping stories content -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshStory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRecentLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECENT UPDATES"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.1"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:paddingBottom="80dp"
                    android:clipToPadding="false"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/layoutEmptyStories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="80dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_story"
                        app:tint="#D1D5DB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No stories yet"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginTop="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Be the first to share a story"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPhotoStory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="36dp"
        android:src="@drawable/ic_plus"
        app:backgroundTint="@color/teal_green"
        app:tint="#FFFFFF"
        app:fabSize="normal"
        android:contentDescription="Add photo story"
        android:elevation="0dp"
        app:maxImageSize="24dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>