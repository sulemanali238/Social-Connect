<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#1E293B"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Privacy &amp; Safety"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"/>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- Header card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/teal_green"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Privacy Matters"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last updated: January 2025"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="We are committed to protecting your personal information and your right to privacy. This policy explains how we collect, use, and safeguard your data."
                            android:textColor="#EEFFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="3dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Section header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Information We Collect"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We collect information you provide directly to us when you create an account, including your name, username, email address, and profile picture. We also collect content you post, comments, likes, and other interactions on the platform."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_privacy"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="How We Use Your Data"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We use the information we collect to provide, maintain, and improve our services, process transactions, send notifications, and personalize your experience. We do not sell your personal data to third parties."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_lock"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Data Security"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction. Your data is stored securely using Firebase infrastructure."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 4 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bell"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cookies and Tracking"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We use Firebase Analytics to understand how users interact with our app. This helps us improve the experience. You can opt out of analytics tracking at any time from your device settings."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 5 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_help"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Rights"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="You have the right to access, correct, or delete your personal data at any time. You can edit your profile information directly in the app or contact us to request full account deletion."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 6 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_setting"
                                    app:tint="@color/teal_green"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Changes to This Policy"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_bold"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F3F4F6"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We may update this Privacy Policy from time to time. We will notify you of any changes by posting the new policy in the app. Your continued use of the app after changes are posted constitutes your acceptance of the updated policy."
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Contact card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#E0F5F1"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Questions about Privacy?"
                            android:textColor="@color/teal_green"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="If you have any questions about this Privacy Policy, please contact us at support@socialconnect.com"
                            android:textColor="#1E293B"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="3dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</RelativeLayout>